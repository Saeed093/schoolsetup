{
  "name": "school-pickup-rfid-system",
  "version": "1.0.0",
  "description": "RFID card management system for school pickup",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "dev:https": "concurrently \"npm run server\" \"npm run client:https\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "client:https": "cd client && npm run start:https",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "install-all:ps": "npm install; if ($?) { cd client; npm install }",
    "uhf-bridge": "cd server/uhf-bridge && python app.py",
    "uhf-bridge:py": "cd server/uhf-bridge && py -3 app.py",
    "dev:with-uhf": "concurrently -n server,client,uhf \"npm run server\" \"npm run client\" \"npm run uhf-bridge\""
  },
  "keywords": [
    "rfid",
    "school",
    "pickup"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "serialport": "^12.0.0",
    "sqlite3": "^5.1.6",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}
